# ADAP Content Gen Web — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── LLM provider (anthropic | openai) ────────────────────────────────────────
# LLM_PROVIDER=anthropic

# ── Anthropic ────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5-20251022

# ── OpenAI ───────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── MCP server (optional) ────────────────────────────────────────────────────
# USE_MCP_SERVER=false
# MCP_SERVER_URL=http://localhost:8090

# ── Flask ─────────────────────────────────────────────────────────────────────
# FLASK_SECRET_KEY=change-me-in-production

# ── Database path (defaults to ./adap.db; override for Fly.io volume) ────────
# DATABASE_PATH=/data/adap.db

# ── Port (defaults to 5001 locally; Fly.io sets this automatically) ───────────
# PORT=5001
